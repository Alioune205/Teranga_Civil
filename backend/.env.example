# Django
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
DB_NAME=sunucivil
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# JWT
ACCESS_TOKEN_LIFETIME=30
REFRESH_TOKEN_LIFETIME=1440

# ==========================================
# ADVANCED SERVICES (DEV 2B & DEV 1C)
# ==========================================

# Redis & Channels (WebSockets / Cache / DRF Throttle)
REDIS_URL=redis://127.0.0.1:6379/1
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Twilio (SMS / OTP)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# SendGrid (Emails transactionnels)
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=no-reply@terangacivil.sn

# Firebase Cloud Messaging (Notifications Push)
FIREBASE_CREDENTIALS_PATH=config/firebase-adminsdk.json

# ==========================================
# GROQ / IA (DEV 1A — Chatbot Ndiogoye)
# ==========================================
# Requis pour activer le Chatbot Ndiogoye (LLM via API Groq).
# Sans cette clé, le chatbot retournera une erreur silencieuse mais
# toutes les autres fonctionnalités (dossiers, OCR, PDF) resteront actives.
# Obtenir une clé gratuite : https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Modèle Groq utilisé par Ndiogoye (optionnel, défaut: llama3-8b-8192)
# GROQ_MODEL=llama3-8b-8192
